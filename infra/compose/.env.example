# Catalog Service - Environment Configuration
# Copy this file to .env and set your values. Never commit .env to git.
#
# For quick local dev: cp .env.example .env
# For production: Set strong POSTGRES_PASSWORD and restrict CORS origins.
# Storage: 'json' (file-based) or 'postgres' (PostgreSQL)
CATALOG_STORAGE=postgres
# Service port (optional, default 8081)
CATALOG_PORT=8081
# PostgreSQL - Database credentials
# For local dev use 'catalog'. For production, set a strong password.
POSTGRES_DB=catalog
POSTGRES_USER=catalog
POSTGRES_PASSWORD=catalog
# PostgreSQL - Connection (catalog uses 'postgres' hostname in Docker)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# CORS allowed origins for frontend (comma-separated)
CATALOG_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -------------------------------------------------------
# Cart Service - Environment Configuration
# -------------------------------------------------------
# Service port (optional, default 8082)
CART_PORT=8082
# PostgreSQL - Database credentials
# For local dev use 'cart'. For production, set a strong password.
CART_POSTGRES_DB=cart
CART_POSTGRES_USER=cart
CART_POSTGRES_PASSWORD=cart
# PostgreSQL - Connection port on host machine
# Using 5433 to avoid conflict with catalog's postgres on 5432
CART_POSTGRES_PORT=5433